# Database connections (separate roles for web vs collector)
# Host: use localhost when running the app directly; use host.docker.internal
# when running via docker compose with Postgres on the Docker host (compose
# maps it via extra_hosts).
DATABASE_URL_WEB=postgresql://usajobs_web:CHANGEME@localhost:5432/usajobs
DATABASE_URL_COLLECTOR=postgresql://usajobs_collector:CHANGEME@localhost:5432/usajobs

# USAJobs API
USAJOBS_API_KEY=your-api-key-here
USAJOBS_USER_AGENT=your-email@example.com

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
